# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini
__pycache__/
tools/__pycache__

# Python virtual environment created by tools/linux-setup.sh
.venv/

# Web app secrets — never commit the real .env
tools/.env

# Runtime files generated by local app launch
.work-notes.log
.work-notes.pid

# Prevent binary/document files from being committed to the inbox.
# Only .md and .txt files belong there; everything else goes in assets/.
inbox/*.pdf
inbox/*.docx
inbox/*.xlsx
inbox/*.xls
inbox/*.pptx
inbox/*.ppt
inbox/*.doc
inbox/*.png
inbox/*.jpg
inbox/*.jpeg
inbox/*.bmp
inbox/*.gif
inbox/*.tiff
inbox/*.tif
inbox/*.svg
inbox/*.heic
inbox/*.webp
