# Copy this file to tools/.env and fill in your values.
# At least one AI provider key is required to use the AI assistant.

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=your_flask_secret_key_here
DEBUG=false
PORT=5000

# ── AI providers ─────────────────────────────────────────────────────────────
# Set the default provider: perplexity | openai | gemini
# Perplexity is recommended — get a key at https://www.perplexity.ai/settings/api
AI_PROVIDER=perplexity

PERPLEXITY_API_KEY=your_perplexity_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
