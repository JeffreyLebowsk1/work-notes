# Copy this file to tools/.env and fill in your values.
# At least one AI provider key is required to use the AI assistant.

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=your_flask_secret_key_here
DEBUG=false
PORT=5000

# ── AI providers ─────────────────────────────────────────────────────────────
# Set the default provider: gemini | openai | perplexity
# Gemini is recommended — get a free key at https://aistudio.google.com/app/apikey
AI_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── Authentication (required for hosted/public deployments) ──────────────────
# Set BOTH to enable HTTP Basic Auth. Leave blank for local use (no auth prompt).
# IMPORTANT: Always set these when hosting on a public URL — the app contains
# internal work notes that must not be publicly accessible.
APP_USERNAME=
APP_PASSWORD=

# ── Upload limit ─────────────────────────────────────────────────────────────
# Maximum asset file size in MB (default: 16).
MAX_UPLOAD_MB=16
